<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SkyBreaker</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:ital,wght@0,300;0,400;0,600;1,300&family=Barlow:wght@300;400&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:#0a0a0a;color:#f0efea;font-family:'Barlow',sans-serif;font-weight:300;overflow-x:hidden;cursor:none}
#cur{position:fixed;width:8px;height:8px;background:#f0efea;border-radius:50%;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);left:-100px;top:-100px}
#cur-ring{position:fixed;width:36px;height:36px;border:1px solid rgba(255,255,255,.35);border-radius:50%;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .3s,height .3s,border-color .3s;left:-100px;top:-100px}
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:14px 48px;display:flex;justify-content:space-between;align-items:center;background:rgba(10,10,10,0.97);border-bottom:1px solid rgba(255,255,255,.06)}
.logo{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:4px;color:#f0efea;text-decoration:none;display:flex;align-items:center;gap:10px}
.logo img{width:64px;height:64px;object-fit:contain;display:block}
nav ul{list-style:none;display:flex;gap:28px}
nav ul li a{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:4px;color:#555;text-decoration:none;text-transform:uppercase;transition:color .2s;cursor:pointer}
nav ul li a:hover,nav ul li a.active{color:#f0efea}
.page{display:none}.page.active{display:block}
/* HERO */
#hero{min-height:100vh;display:flex;flex-direction:column;justify-content:flex-end;padding:0 48px 80px;position:relative;overflow:hidden}
.grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.05) 1px,transparent 1px);background-size:80px 80px;animation:gridMove 18s linear infinite}
@keyframes gridMove{from{transform:translateY(0)}to{transform:translateY(80px)}}
.hero-num{position:absolute;right:32px;top:50%;transform:translateY(-50%);font-family:'Bebas Neue',sans-serif;font-size:260px;color:rgba(255,255,255,.02);line-height:1;user-select:none}
.hero-eye{position:relative;font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:6px;color:#555;margin-bottom:20px;animation:fadeUp .7s .2s both}
.hero-h1{position:relative;font-family:'Bebas Neue',sans-serif;font-size:clamp(72px,13vw,168px);line-height:.88;letter-spacing:2px;animation:fadeUp .8s .35s both}
.hero-h1 .dim{color:#aaa}
.hero-bot{position:relative;display:flex;justify-content:space-between;align-items:flex-end;margin-top:40px;padding-top:24px;border-top:1px solid rgba(255,255,255,.07);animation:fadeUp .7s .6s both}
.hero-slogan{font-family:'Barlow Condensed',sans-serif;font-size:17px;letter-spacing:3px;font-style:italic;color:#aaa}
.hero-scroll{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:4px;color:#555;display:flex;align-items:center;gap:14px}
.sbar{width:40px;height:1px;background:#444;overflow:hidden;position:relative}
.sbar::after{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:#f0efea;animation:scan 2s ease-in-out infinite}
@keyframes scan{from{left:-100%}to{left:100%}}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
section{padding:120px 48px}
.sec-lbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:6px;color:#555;margin-bottom:56px;display:flex;align-items:center;gap:20px;text-transform:uppercase}
.sec-lbl::after{content:'';width:160px;height:1px;background:rgba(255,255,255,.07)}
.sec-h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(48px,7vw,88px);line-height:.9;letter-spacing:1px;margin-bottom:56px}
/* A PROPOS */
#apropos{background:#0a0a0a}
.apropos-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:2px}
.apropos-card{background:#141414;padding:40px 36px}
.apropos-card-label{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:5px;color:#555;text-transform:uppercase;margin-bottom:20px}
.apropos-card-text{font-family:'Barlow',sans-serif;font-size:17px;line-height:1.8;color:#ccc;font-weight:300}
.apropos-card-text strong{color:#f0efea;font-weight:400}
.apropos-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.apropos-stat{background:#141414;padding:28px 36px;border-left:2px solid rgba(255,255,255,.07)}
.apropos-stat-num{font-family:'Bebas Neue',sans-serif;font-size:52px;color:#f0efea;line-height:1}
.apropos-stat-label{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:4px;color:#555;text-transform:uppercase;margin-top:6px}
/* EQUIPE */
#equipe{background:#1c1c1c}
.team{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:2px}
.card{background:#0a0a0a;padding:30px 26px;position:relative;overflow:hidden;transition:background .3s}
.card::after{content:'';position:absolute;bottom:0;left:0;width:100%;height:2px;background:#f0efea;transform:scaleX(0);transform-origin:left;transition:transform .35s ease}
.card:hover{background:#111}.card:hover::after{transform:scaleX(1)}
.card-num{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;color:#555;margin-bottom:18px}
.card-name{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:1px;color:#f0efea;line-height:1;margin-bottom:6px}
.card-role{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;color:#555}
.card-letter{position:absolute;right:-8px;bottom:-12px;font-family:'Bebas Neue',sans-serif;font-size:80px;color:rgba(255,255,255,.025);line-height:1;user-select:none;transition:color .3s}
.card:hover .card-letter{color:rgba(255,255,255,.055)}
/* CALENDRIER */
#calendrier{background:#0a0a0a}
.callist{display:flex;flex-direction:column;gap:2px}
.calrow{display:grid;grid-template-columns:90px 1fr auto;align-items:center;gap:32px;padding:26px 28px;background:#141414;border-left:2px solid transparent;transition:border-color .3s,background .3s,transform .25s}
.calrow:hover{border-color:#f0efea;background:#1a1a1a;transform:translateX(6px)}
.cal-day{font-family:'Bebas Neue',sans-serif;font-size:30px;color:#f0efea;line-height:1}
.cal-mo{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;color:#555}
.cal-ev{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1px;color:#f0efea;margin-bottom:4px}
.cal-pl{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;color:#555}
.badge{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;padding:4px 10px;border:1px solid;white-space:nowrap;font-weight:600}
.done{color:#555;border-color:rgba(255,255,255,.1);text-decoration:line-through}
.open{color:#7dff7d;border-color:rgba(125,255,125,.25)}
.soon{color:#aaa;border-color:rgba(255,255,255,.18)}
/* FOOTER */
footer{background:#1c1c1c;padding:56px 48px;display:flex;justify-content:space-between;align-items:center;border-top:1px solid rgba(255,255,255,.07)}
.ft-name{font-family:'Bebas Neue',sans-serif;font-size:30px;letter-spacing:4px}
.ft-sub{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:4px;color:#555;font-style:italic;margin-top:4px}
.ft-info{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:2px;color:#555;text-align:right;line-height:2}
/* GENERATEUR */
#gen-page{padding-top:92px;background:#0a0a0a;min-height:100vh}
.gen-wrap{padding:40px 48px 60px}
.gen-header{border-bottom:1px solid rgba(255,255,255,.07);padding-bottom:24px;margin-bottom:40px}
.gen-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,5vw,64px);letter-spacing:2px;line-height:1;color:#f0efea}
.gen-title span{color:#333}
.gen-subtitle{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:4px;color:#444;text-transform:uppercase;margin-top:10px}
.gen-body{display:grid;grid-template-columns:1fr 1fr;gap:2px}
.gen-params{display:flex;flex-direction:column;gap:2px}
.gen-preview-col{background:#0f0f0f;border:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;gap:20px;min-height:480px}
.param-block{background:#141414;padding:24px 28px}
.param-title{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:5px;color:#444;text-transform:uppercase;margin-bottom:16px}
.param-options{display:flex;gap:2px;flex-wrap:wrap}
.param-btn{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;padding:10px 18px;background:#1a1a1a;border:1px solid rgba(255,255,255,.08);color:#666;cursor:pointer;transition:all .2s}
.param-btn:hover{color:#ccc;border-color:rgba(255,255,255,.2)}
.param-btn.sel{background:#f0efea;color:#0a0a0a;border-color:#f0efea}
.preview-label{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:5px;color:#333;text-transform:uppercase}
#genCanvas{display:block}
.gen-stats{display:grid;grid-template-columns:1fr 1fr;gap:2px;width:100%}
.gen-stat{background:#1a1a1a;padding:12px 16px;text-align:center}
.gen-stat-label{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:3px;color:#444;text-transform:uppercase;margin-bottom:4px}
.gen-stat-val{font-family:'Bebas Neue',sans-serif;font-size:22px;color:#f0efea}
.btn-test{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:4px;color:#0a0a0a;background:#f0efea;border:none;padding:16px 48px;cursor:pointer;transition:opacity .2s;width:100%}
.btn-test:hover{opacity:.85}
.mode-badge{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;padding:3px 10px;border:1px solid rgba(255,255,255,.15);color:#aaa}
/* SIMULATEUR */
#sim-page{padding-top:92px;background:#0a0a0a;min-height:100vh}
.sim-wrap{padding:40px 48px 60px}
.sim-header{display:flex;justify-content:space-between;align-items:flex-end;border-bottom:1px solid rgba(255,255,255,.07);padding-bottom:24px;margin-bottom:24px}
.sim-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,5vw,64px);letter-spacing:2px;line-height:1;color:#f0efea}
.sim-title span{color:#333}
.sim-hint{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;color:#444;text-transform:uppercase;text-align:right;line-height:1.8}
.sim-plane-badge{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;color:#555;padding:4px 12px;border:1px solid rgba(255,255,255,.1);display:inline-block;margin-bottom:12px}
.sim-canvas-wrap{position:relative;width:100%;border:1px solid rgba(255,255,255,.07);background:#0c0c0c;overflow:hidden}
#simCanvas{display:block;cursor:crosshair;width:100%}
.cam-indicator{position:absolute;bottom:10px;right:12px;font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:3px;color:rgba(255,255,255,.2);pointer-events:none}
.sim-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;margin-top:2px}
.stat-box{background:#141414;padding:20px 28px}
.stat-label{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:4px;color:#444;text-transform:uppercase;margin-bottom:8px}
.stat-val{font-family:'Bebas Neue',sans-serif;font-size:40px;letter-spacing:1px;color:#f0efea;line-height:1}
.stat-unit{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:3px;color:#444;margin-top:4px}
.sim-footer{display:flex;align-items:center;gap:20px;margin-top:16px}
.btn-reset{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:4px;text-transform:uppercase;color:#0a0a0a;background:#f0efea;border:none;padding:12px 32px;cursor:pointer;transition:opacity .2s}
.btn-reset:hover{opacity:.8}
.sim-msg{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;color:#444;font-style:italic}
@media(max-width:800px){
  nav{padding:14px 20px}nav ul{gap:10px}
  section,#hero{padding-left:20px;padding-right:20px}#hero{padding-bottom:56px}
  .calrow{grid-template-columns:70px 1fr}.badge{display:none}
  footer{flex-direction:column;gap:20px}.ft-info{text-align:left}
  .gen-wrap,.sim-wrap{padding:24px 20px 40px}
  .gen-body{grid-template-columns:1fr}
  .sim-stats{grid-template-columns:1fr 1fr}
  .sim-header{flex-direction:column;align-items:flex-start;gap:12px}
  .apropos-grid{grid-template-columns:1fr}
  .apropos-stats{grid-template-columns:1fr}
}
</style>
</head>
<body>
<div id="cur"></div>
<div id="cur-ring"></div>
<nav>
  <a class="logo" href="#" onclick="goPage('main');return false">
    <img src="data:image/png;base64," alt="logo">SkyBreaker
  </a>
  <ul>
    <li><a id="na-accueil" class="active" onclick="goPage('main');return false" href="#">Accueil</a></li>
    <li><a id="na-apropos" onclick="goPage('main');scrollSec('apropos');return false" href="#">À Propos</a></li>
    <li><a id="na-equipe" onclick="goPage('main');scrollSec('equipe');return false" href="#">Équipe</a></li>
    <li><a id="na-comp" onclick="goPage('main');scrollSec('calendrier');return false" href="#">Sessions Test</a></li>
    <li><a id="na-gen" onclick="goPage('gen');return false" href="#">Générateur</a></li>
    <li><a id="na-sim" onclick="goPage('sim');return false" href="#">Simulation</a></li>
  </ul>
</nav>

<!-- MAIN -->
<div id="main-page" class="page active">
  <section id="hero">
    <div class="grid-bg"></div>
    <div class="hero-num">01</div>
    <p class="hero-eye">Paper Aviation · Compétition Élite · 2026</p>
    <h1 class="hero-h1">SKY<br><span class="dim">BREAKER</span></h1>
    <div class="hero-bot">
      <span class="hero-slogan">"Born to break limits."</span>
      <span class="hero-scroll"><span class="sbar"></span>Défiler</span>
    </div>
  </section>

  <section id="apropos">
    <p class="sec-lbl">02 — À Propos</p>
    <h2 class="sec-h2">Le<br>Projet</h2>
    <div class="apropos-grid">
      <div class="apropos-card">
        <p class="apropos-card-label">La mission</p>
        <p class="apropos-card-text">SkyBreaker est une compétition d'avions en papier entre équipes. Un seul objectif : <strong>voler le plus loin et le plus droit possible.</strong> Pas de moteur, pas de triche — juste du papier, de la technique, et de la précision.</p>
      </div>
      <div class="apropos-card">
        <p class="apropos-card-label">Le format</p>
        <p class="apropos-card-text">Plusieurs équipes s'affrontent lors de sessions test tout au long de l'année 2026. Chaque lancer est chronométré, mesuré, analysé. <strong>Une seule équipe sortira au sommet.</strong></p>
      </div>
    </div>
    <div class="apropos-stats">
      <div class="apropos-stat">
        <div class="apropos-stat-num">2–3</div>
        <div class="apropos-stat-label">Équipes en compétition</div>
      </div>
      <div class="apropos-stat">
        <div class="apropos-stat-num">5</div>
        <div class="apropos-stat-label">Sessions test 2026</div>
      </div>
      <div class="apropos-stat">
        <div class="apropos-stat-num">1</div>
        <div class="apropos-stat-label">Vainqueur final</div>
      </div>
    </div>
  </section>

  <section id="equipe">
    <p class="sec-lbl">03 — Équipe</p>
    <h2 class="sec-h2">Le<br>Staff</h2>
    <div class="team">
      <div class="card"><div class="card-num">No. 01</div><div class="card-name">Arthur L.</div><div class="card-role">Responsable Marketing</div><div class="card-letter">A</div></div>
      <div class="card"><div class="card-num">No. 02</div><div class="card-name">Arthur V.</div><div class="card-role">Responsable Marketing</div><div class="card-letter">A</div></div>
      <div class="card"><div class="card-num">No. 03</div><div class="card-name">Hanad D.</div><div class="card-role">Développeur Avion</div><div class="card-letter">H</div></div>
      <div class="card"><div class="card-num">No. 04</div><div class="card-name">Nael D.</div><div class="card-role">Développeur Avion</div><div class="card-letter">N</div></div>
      <div class="card"><div class="card-num">No. 05</div><div class="card-name">Adonis B.</div><div class="card-role">Chef du Département Juridique</div><div class="card-letter">A</div></div>
      <div class="card"><div class="card-num">No. 06</div><div class="card-name">Léa T.</div><div class="card-role">Responsable Recherche</div><div class="card-letter">L</div></div>
      <div class="card"><div class="card-num">No. 07</div><div class="card-name">Lauren F.</div><div class="card-role">Responsable Recherche</div><div class="card-letter">L</div></div>
    </div>
  </section>

  <section id="calendrier">
    <p class="sec-lbl">04 — Sessions Test</p>
    <h2 class="sec-h2">Sessions<br>Test 2026</h2>
    <div class="callist">
      <div class="calrow"><div><div class="cal-day">24</div><div class="cal-mo">Avr 2026</div></div><div><div class="cal-ev">Session Test — No. 01</div><div class="cal-pl">Reprise après vacances de Pâques</div></div><div class="badge open">À venir</div></div>
      <div class="calrow"><div><div class="cal-day">01</div><div class="cal-mo">Mai 2026</div></div><div><div class="cal-ev">Session Test — No. 02</div><div class="cal-pl">Fête du Travail — sous réserve</div></div><div class="badge soon">À venir</div></div>
      <div class="calrow"><div><div class="cal-day">08</div><div class="cal-mo">Mai 2026</div></div><div><div class="cal-ev">Session Test — No. 03</div><div class="cal-pl">Session de mai</div></div><div class="badge soon">À venir</div></div>
      <div class="calrow"><div><div class="cal-day">15</div><div class="cal-mo">Mai 2026</div></div><div><div class="cal-ev">Session Test — No. 04</div><div class="cal-pl">Session de mai</div></div><div class="badge soon">À venir</div></div>
      <div class="calrow"><div><div class="cal-day">22</div><div class="cal-mo">Mai 2026</div></div><div><div class="cal-ev">Session Test — No. 05</div><div class="cal-pl">Session finale</div></div><div class="badge soon">À venir</div></div>
    </div>
  </section>

  <footer>
    <div><div class="ft-name">SkyBreaker</div><div class="ft-sub">Born to break limits.</div></div>
    <div class="ft-info">skybreaker.fr<br>contact@skybreaker.fr<br>Genève · 2026</div>
  </footer>
</div>

<!-- GENERATEUR -->
<div id="gen-page" class="page">
  <div class="gen-wrap">
    <div class="gen-header">
      <div class="gen-title">GÉNÉ<br><span>RATEUR</span></div>
      <div class="gen-subtitle">Configure ton avion puis teste-le dans le simulateur</div>
    </div>
    <div class="gen-body">
      <div class="gen-params">
        <div class="param-block">
          <div class="param-title">Mode de vol</div>
          <div class="param-options">
            <button class="param-btn sel" data-param="mode" data-val="planeur">Planeur</button>
            <button class="param-btn" data-param="mode" data-val="rapide">Rapide</button>
            <button class="param-btn" data-param="mode" data-val="acrobatique">Acrobatique</button>
            <button class="param-btn" data-param="mode" data-val="longue-distance">Longue Distance</button>
          </div>
        </div>
        <div class="param-block">
          <div class="param-title">Forme des ailes</div>
          <div class="param-options">
            <button class="param-btn sel" data-param="ailes" data-val="standard">Standard</button>
            <button class="param-btn" data-param="ailes" data-val="longues">Longues</button>
            <button class="param-btn" data-param="ailes" data-val="courtes">Courtes</button>
            <button class="param-btn" data-param="ailes" data-val="delta">Delta</button>
          </div>
        </div>
        <div class="param-block">
          <div class="param-title">Type de nez</div>
          <div class="param-options">
            <button class="param-btn sel" data-param="nez" data-val="pointu">Pointu</button>
            <button class="param-btn" data-param="nez" data-val="arrondi">Arrondi</button>
            <button class="param-btn" data-param="nez" data-val="aplati">Aplati</button>
          </div>
        </div>
        <div class="param-block">
          <div class="param-title">Longueur du fuselage</div>
          <div class="param-options">
            <button class="param-btn" data-param="fuselage" data-val="court">Court</button>
            <button class="param-btn sel" data-param="fuselage" data-val="moyen">Moyen</button>
            <button class="param-btn" data-param="fuselage" data-val="long">Long</button>
          </div>
        </div>
      </div>
      <div class="gen-preview-col">
        <div class="preview-label">Aperçu</div>
        <canvas id="genCanvas" width="320" height="200"></canvas>
        <div id="genModeBadge" class="mode-badge">PLANEUR</div>
        <div class="gen-stats">
          <div class="gen-stat"><div class="gen-stat-label">Portance</div><div class="gen-stat-val" id="gLift">++</div></div>
          <div class="gen-stat"><div class="gen-stat-label">Vitesse</div><div class="gen-stat-val" id="gSpeed">++</div></div>
          <div class="gen-stat"><div class="gen-stat-label">Stabilité</div><div class="gen-stat-val" id="gStab">+++</div></div>
          <div class="gen-stat"><div class="gen-stat-label">Distance max</div><div class="gen-stat-val" id="gDist">~18m</div></div>
        </div>
        <button class="btn-test" onclick="testPlane()">▶ TESTER DANS LE SIMULATEUR</button>
      </div>
    </div>
  </div>
</div>

<!-- SIMULATEUR -->
<div id="sim-page" class="page">
  <div class="sim-wrap">
    <div class="sim-header">
      <div class="sim-title">SIMUL<br><span>ATEUR</span></div>
      <div class="sim-hint">Cliquer + glisser pour viser<br>Relâcher pour lancer</div>
    </div>
    <div id="simPlaneBadge" class="sim-plane-badge" style="display:none"></div>
    <div class="sim-canvas-wrap" id="simWrap">
      <canvas id="simCanvas"></canvas>
      <div class="cam-indicator" id="camInd">CAM LIBRE</div>
    </div>
    <div class="sim-stats">
      <div class="stat-box"><div class="stat-label">Distance</div><div class="stat-val" id="sDist">0.0</div><div class="stat-unit">mètres</div></div>
      <div class="stat-box"><div class="stat-label">Durée du vol</div><div class="stat-val" id="sTime">0.00</div><div class="stat-unit">secondes</div></div>
      <div class="stat-box"><div class="stat-label">Vitesse max</div><div class="stat-val" id="sSpd">0.0</div><div class="stat-unit">m / s</div></div>
    </div>
    <div class="sim-footer">
      <button class="btn-reset" id="btnReset">↺ Réinitialiser</button>
      <span class="sim-msg" id="sMsg">Cliquez et glissez pour lancer l'avion.</span>
    </div>
  </div>
</div>

<script>
/* ======= CONSTANTES ======= */
const WW = 40;
const WH = 30;
const G  = 9.81;
const MAXSPD = 15;
const SX = WW * 0.12;
const SY = 0;

/* ======= NAVIGATION ======= */
function goPage(p) {
  document.querySelectorAll('.page').forEach(e => e.classList.remove('active'));
  document.querySelectorAll('nav ul li a').forEach(e => e.classList.remove('active'));
  const pmap = {main:'main-page', gen:'gen-page', sim:'sim-page'};
  const nmap = {main:'na-accueil', gen:'na-gen', sim:'na-sim'};
  document.getElementById(pmap[p]).classList.add('active');
  document.getElementById(nmap[p]).classList.add('active');
  window.scrollTo(0,0);
  if (p === 'gen') setTimeout(drawGen, 50);
  if (p === 'sim') setTimeout(initSim, 50);
}
function scrollSec(id) {
  setTimeout(() => { const el = document.getElementById(id); if (el) el.scrollIntoView({behavior:'smooth'}); }, 60);
}

/* ======= CURSEUR ======= */
const cD = document.getElementById('cur');
const cR = document.getElementById('cur-ring');
let mx=0, my=0, rx=0, ry=0;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cD.style.left = mx+'px'; cD.style.top = my+'px';
});
(function loop() {
  rx += (mx-rx)*0.12; ry += (my-ry)*0.12;
  cR.style.left = rx+'px'; cR.style.top = ry+'px';
  requestAnimationFrame(loop);
})();
document.querySelectorAll('a,.card,.calrow,.btn-reset,.btn-test,.param-btn').forEach(el => {
  el.addEventListener('mouseenter', () => { cR.style.width=cR.style.height='54px'; cR.style.borderColor='rgba(255,255,255,.7)'; });
  el.addEventListener('mouseleave', () => { cR.style.width=cR.style.height='36px'; cR.style.borderColor='rgba(255,255,255,.35)'; });
});

/* ======= GENERATEUR ======= */
const cfg = { mode:'planeur', ailes:'standard', nez:'pointu', fuselage:'moyen' };
const PHYS = {
  mode: {
    planeur:           { sm:.7,  lm:1.4, st:1.2, gm:.85 },
    rapide:            { sm:1.5, lm:.8,  st:.9,  gm:1.0 },
    acrobatique:       { sm:1.2, lm:1.0, st:.7,  gm:1.1 },
    'longue-distance': { sm:1.0, lm:1.2, st:1.3, gm:.8  }
  },
  ailes:    { standard:{sm:1.0,lm:1.0,st:1.0}, longues:{sm:.85,lm:1.4,st:1.2}, courtes:{sm:1.3,lm:.7,st:.8}, delta:{sm:1.4,lm:.9,st:1.1} },
  nez:      { pointu:{sm:1.2,lm:.9,st:1.0}, arrondi:{sm:.9,lm:1.1,st:1.1}, aplati:{sm:.8,lm:1.2,st:.9} },
  fuselage: { court:{sm:1.1,lm:.9,st:.85}, moyen:{sm:1.0,lm:1.0,st:1.0}, long:{sm:.9,lm:1.1,st:1.15} }
};

function getPhys() {
  let sm=1, lm=1, st=1, gm=1;
  ['mode','ailes','nez','fuselage'].forEach(k => {
    const c = PHYS[k][cfg[k]];
    sm *= c.sm; lm *= c.lm; st *= c.st; if (c.gm) gm *= c.gm;
  });
  return { sm, lm, st, gm };
}

function stars(v, m) { return '+'.repeat(Math.max(1, Math.min(Math.round(v * m), m + 1))); }

function updateGenUI() {
  const p = getPhys();
  document.getElementById('gLift').textContent  = stars(p.lm, 3);
  document.getElementById('gSpeed').textContent = stars(p.sm, 3);
  document.getElementById('gStab').textContent  = stars(p.st, 3);
  document.getElementById('gDist').textContent  = '~' + Math.min(Math.round(p.sm * p.lm * 15 * 1.3), 28) + 'm';
  const ml = { planeur:'PLANEUR', rapide:'RAPIDE', acrobatique:'ACROBATIQUE', 'longue-distance':'LONGUE DISTANCE' };
  document.getElementById('genModeBadge').textContent = ml[cfg.mode];
}

document.querySelectorAll('.param-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.param-btn[data-param="'+btn.dataset.param+'"]').forEach(b => b.classList.remove('sel'));
    btn.classList.add('sel');
    cfg[btn.dataset.param] = btn.dataset.val;
    drawGen();
  });
});

function drawGen() {
  const cv = document.getElementById('genCanvas'), c = cv.getContext('2d');
  const W = cv.width, H = cv.height;
  c.clearRect(0,0,W,H); c.fillStyle='#0c0c0c'; c.fillRect(0,0,W,H);
  c.strokeStyle='rgba(255,255,255,.04)'; c.lineWidth=1;
  for (let x=0;x<W;x+=32) { c.beginPath(); c.moveTo(x,0); c.lineTo(x,H); c.stroke(); }
  for (let y=0;y<H;y+=32) { c.beginPath(); c.moveTo(0,y); c.lineTo(W,y); c.stroke(); }
  const cx=W/2, cy=H/2;
  const fL = cfg.fuselage==='court'?55 : cfg.fuselage==='long'?90 : 70;
  const ws = cfg.ailes==='longues'?75 : cfg.ailes==='courtes'?35 : cfg.ailes==='delta'?55 : 50;
  const nL = cfg.nez==='pointu'?28 : cfg.nez==='arrondi'?18 : 12;
  const nH = cfg.nez==='aplati'?10 : cfg.nez==='arrondi'?6 : 2;
  const isDelta = cfg.ailes==='delta';
  c.save(); c.translate(cx, cy);
  c.fillStyle='#c8c8c8'; c.beginPath();
  if (cfg.nez==='pointu') { c.moveTo(fL/2+nL,0); c.lineTo(fL/2,-5); c.lineTo(-fL/2,-4); c.lineTo(-fL/2,4); c.lineTo(fL/2,5); }
  else if (cfg.nez==='arrondi') { c.moveTo(fL/2+nL,0); c.bezierCurveTo(fL/2+nL+4,-nH,fL/2,-8,-fL/2,-4); c.lineTo(-fL/2,4); c.bezierCurveTo(fL/2,8,fL/2+nL+4,nH,fL/2+nL,0); }
  else { c.moveTo(fL/2+nL,-nH); c.lineTo(fL/2+nL,nH); c.lineTo(-fL/2,5); c.lineTo(-fL/2,-5); }
  c.closePath(); c.fill();
  c.fillStyle='#f0efea';
  if (isDelta) { c.beginPath(); c.moveTo(fL/2,0); c.lineTo(-fL/2+10,-ws); c.lineTo(-fL/2,0); c.closePath(); c.fill(); }
  else { c.beginPath(); c.moveTo(fL/4,0); c.lineTo(-fL/4,-ws); c.lineTo(-fL/2,-4); c.lineTo(fL/4,-3); c.closePath(); c.fill(); }
  c.fillStyle='#666';
  if (isDelta) { c.beginPath(); c.moveTo(fL/2,0); c.lineTo(-fL/2+10,ws); c.lineTo(-fL/2,0); c.closePath(); c.fill(); }
  else { c.beginPath(); c.moveTo(fL/4,0); c.lineTo(-fL/4,ws); c.lineTo(-fL/2,4); c.lineTo(fL/4,3); c.closePath(); c.fill(); }
  c.fillStyle='#aaa'; c.beginPath(); c.moveTo(-fL/2+8,0); c.lineTo(-fL/2-10,-18); c.lineTo(-fL/2-2,0); c.closePath(); c.fill();
  c.strokeStyle='rgba(10,10,10,.8)'; c.lineWidth=1.5; c.beginPath(); c.moveTo(fL/2+nL-4,0); c.lineTo(-fL/2,0); c.stroke();
  if (cfg.mode==='acrobatique') {
    c.strokeStyle='rgba(255,80,80,.7)'; c.lineWidth=2;
    c.beginPath(); c.moveTo(-fL/4,-ws*.6); c.lineTo(-fL/4+12,-ws*.6); c.stroke();
    c.beginPath(); c.moveTo(-fL/4,ws*.6); c.lineTo(-fL/4+12,ws*.6); c.stroke();
  }
  if (cfg.mode==='rapide') {
    c.strokeStyle='rgba(255,200,80,.5)'; c.lineWidth=8; c.globalAlpha=.25;
    c.beginPath(); c.moveTo(fL/2+nL+4,0); c.lineTo(fL/2+nL+28,0); c.stroke(); c.globalAlpha=1;
  }
  c.restore();
  updateGenUI();
}

let simPhys=null, simName=null, simAiles='standard';
function testPlane() {
  simPhys = getPhys();
  simName = [cfg.mode, cfg.ailes, cfg.nez, cfg.fuselage].join(' · ');
  simAiles = cfg.ailes;
  goPage('sim');
}

/* ======= SIMULATEUR ======= */
let cv2, ctx2, ready=false, state='idle';
let ms = { down:false, x0:0, y0:0, x:0, y:0 };
let pl = {}, trail=[], t0=0, tN=0, vmax=0, raf=null;
let ph = { sm:1, lm:1, st:1, gm:1 };
let camX=0, camXT=0;
let resetTimer=null;

function initSim() {
  cv2 = document.getElementById('simCanvas');
  ctx2 = cv2.getContext('2d');
  const badge = document.getElementById('simPlaneBadge');
  if (simPhys) {
    badge.textContent = '✦ ' + simName.toUpperCase();
    badge.style.display = 'inline-block';
    ph = simPhys;
  } else {
    badge.style.display = 'none';
    ph = { sm:1, lm:1, st:1, gm:1 };
  }
  resize2();
  if (!ready) {
    ready = true;
    window.addEventListener('resize', resize2);
    cv2.addEventListener('mousedown',  onMD);
    cv2.addEventListener('mousemove',  onMM);
    cv2.addEventListener('mouseup',    onMU);
    cv2.addEventListener('mouseleave', onML);
    cv2.addEventListener('touchstart', e => { e.preventDefault(); onMD(e.touches[0]); }, {passive:false});
    cv2.addEventListener('touchmove',  e => { e.preventDefault(); onMM(e.touches[0]); }, {passive:false});
    cv2.addEventListener('touchend',   e => { e.preventDefault(); onMU(e.changedTouches[0]); }, {passive:false});
    document.getElementById('btnReset').addEventListener('click', resetSim);
  }
  resetSim();
}

function resize2() {
  if (!cv2) return;
  const W = document.getElementById('simWrap').clientWidth;
  cv2.width  = W;
  cv2.height = Math.round(W * WH / WW);
  document.getElementById('simWrap').style.height = cv2.height + 'px';
  if (state !== 'flying') render();
}

function w2s(wx, wy) {
  return {
    x: ((wx - camX) / WW) * cv2.width,
    y: cv2.height - (wy / WH) * cv2.height
  };
}

function getPos(e) { const r = cv2.getBoundingClientRect(); return { x: e.clientX-r.left, y: e.clientY-r.top }; }

function onMD(e) {
  if (state === 'flying') return;
  if (resetTimer) { clearTimeout(resetTimer); resetTimer=null; doReset(); }
  const p = getPos(e);
  ms = { down:true, x0:p.x, y0:p.y, x:p.x, y:p.y };
  state = 'aiming';
  render();
}
function onMM(e) { if (!ms.down) return; const p=getPos(e); ms.x=p.x; ms.y=p.y; if (state==='aiming') render(); }
function onMU(e) { if (!ms.down || state!=='aiming') return; ms.down=false; const p=getPos(e); ms.x=p.x; ms.y=p.y; launch(); }
function onML() { if (ms.down && state==='aiming') { ms.down=false; launch(); } }

function launch() {
  const dx = ms.x0 - ms.x, dy = ms.y0 - ms.y;
  const dist = Math.sqrt(dx*dx + dy*dy);
  if (dist < 6) { state='idle'; render(); return; }
  const maxD = Math.sqrt(cv2.width*cv2.width + cv2.height*cv2.height) * 0.4;
  const power = Math.min(dist / maxD, 1);
  const spd = (3 + power * MAXSPD) * ph.sm;
  const angle = Math.atan2(dy, dx);
  pl = { wx:SX, wy:SY, vx:spd*Math.cos(angle), vy:spd*Math.sin(-angle) };
  trail = []; vmax = spd; t0 = performance.now(); tN = t0;
  state = 'flying';
  setMsg('En vol…');
  if (raf) cancelAnimationFrame(raf);
  raf = requestAnimationFrame(tick);
}

function tick(ts) {
  const dt = Math.min((ts - tN) / 1000, 0.033); tN = ts;
  const elapsed = (ts - t0) / 1000;
  const effG = G * ph.gm;
  const lift = Math.max(0, pl.vx) * 0.012 * ph.lm;
  pl.vy -= (effG - lift) * dt;
  pl.wx += pl.vx * dt;
  pl.wy += pl.vy * dt;
  const spd = Math.sqrt(pl.vx*pl.vx + pl.vy*pl.vy);
  if (spd > vmax) vmax = spd;
  const dist = Math.max(0, pl.wx - SX);
  setStats(dist, elapsed, vmax);
  trail.push({ wx:pl.wx, wy:pl.wy });
  if (trail.length > 500) trail.shift();
  const frac = (pl.wx - camX) / WW;
  if (frac > 0.65) camXT = pl.wx - WW * 0.45;
  if (frac < 0.20) camXT = Math.max(0, pl.wx - WW * 0.25);
  camX += (camXT - camX) * 0.1;
  document.getElementById('camInd').textContent = camX > 0.5 ? 'CAM SUIVI ✦' : 'CAM LIBRE';
  render();
  if (pl.wy <= 0 || pl.wy > WH * 1.5) {
    if (pl.wy < 0) pl.wy = 0;
    state = 'done';
    const fd = Math.max(0, pl.wx - SX);
    setStats(fd, elapsed, vmax);
    setMsg('Atterrissage ! ' + fd.toFixed(2) + ' m en ' + elapsed.toFixed(2) + ' s — Prêt pour le prochain lancer.');
    render();
    resetTimer = setTimeout(() => { resetTimer=null; doReset(); }, 2000);
    return;
  }
  raf = requestAnimationFrame(tick);
}

function doReset() {
  if (raf) { cancelAnimationFrame(raf); raf=null; }
  camX=0; camXT=0;
  pl = { wx:SX, wy:SY, vx:0, vy:0 };
  trail = []; vmax = 0; state = 'idle';
  document.getElementById('camInd').textContent = 'CAM LIBRE';
  render();
}

function resetSim() {
  if (resetTimer) { clearTimeout(resetTimer); resetTimer=null; }
  doReset();
  setStats(0,0,0);
  setMsg("Cliquez et glissez pour lancer l'avion.");
}

function setStats(d,t,s) {
  document.getElementById('sDist').textContent = d.toFixed(1);
  document.getElementById('sTime').textContent = t.toFixed(2);
  document.getElementById('sSpd').textContent  = s.toFixed(1);
}
function setMsg(m) { document.getElementById('sMsg').textContent = m; }

/* ======= RENDU ======= */
function render() {
  if (!cv2 || !ctx2) return;
  const W = cv2.width, H = cv2.height;
  ctx2.clearRect(0,0,W,H);
  rGrid(W,H); rGround(W,H); rRuler(W,H);
  if (state === 'aiming') rAim(W,H);
  if (state === 'flying' || state === 'done') { rTrail(); if (state==='done') rMark(); }
  rPlane();
}

function rGrid(W,H) {
  ctx2.save(); ctx2.lineWidth=1;
  const s5 = Math.floor(camX/5)*5;
  for (let m=s5; m<=camX+WW+5; m+=5) {
    const p = w2s(m,0);
    ctx2.strokeStyle = m%10===0 ? 'rgba(255,255,255,.07)' : 'rgba(255,255,255,.03)';
    ctx2.beginPath(); ctx2.moveTo(p.x,0); ctx2.lineTo(p.x,H); ctx2.stroke();
  }
  for (let m=0; m<=WH; m+=5) {
    const p = w2s(0,m);
    ctx2.strokeStyle = 'rgba(255,255,255,.04)';
    ctx2.beginPath(); ctx2.moveTo(0,p.y); ctx2.lineTo(W,p.y); ctx2.stroke();
  }
  ctx2.restore();
}

function rGround(W,H) {
  const g = w2s(0,0); ctx2.save();
  ctx2.fillStyle='rgba(255,255,255,.03)'; ctx2.fillRect(0,g.y,W,H-g.y);
  ctx2.strokeStyle='rgba(255,255,255,.2)'; ctx2.lineWidth=1;
  ctx2.beginPath(); ctx2.moveTo(0,g.y); ctx2.lineTo(W,g.y); ctx2.stroke();
  ctx2.restore();
}

function rRuler(W,H) {
  const gy = w2s(0,0).y;
  ctx2.save();
  ctx2.font = '10px "Barlow Condensed",sans-serif';
  ctx2.fillStyle = 'rgba(120,120,120,.7)'; ctx2.textAlign='center';
  const s5 = Math.floor(camX/5)*5;
  for (let m=s5; m<=camX+WW+5; m+=5) {
    if (m<0) continue;
    const p = w2s(m,0);
    if (p.x<0||p.x>W) continue;
    ctx2.fillText(m+'m', p.x, gy+14);
    ctx2.strokeStyle='rgba(255,255,255,.15)'; ctx2.lineWidth=1;
    ctx2.beginPath(); ctx2.moveTo(p.x,gy); ctx2.lineTo(p.x,gy+5); ctx2.stroke();
  }
  ctx2.textAlign='left'; ctx2.fillStyle='rgba(80,80,80,.8)';
  for (let m=5; m<=WH; m+=5) {
    const p = w2s(0,m);
    if (p.y<0||p.y>H) continue;
    ctx2.fillText(m+'m', 4, p.y+4);
  }
  ctx2.restore();
}

function rAim(W,H) {
  const sp = w2s(pl.wx, pl.wy);
  const dx = ms.x0-ms.x, dy = ms.y0-ms.y;
  const dist = Math.sqrt(dx*dx+dy*dy); if (dist<4) return;
  const power = Math.min(dist / (Math.sqrt(W*W+H*H)*0.4), 1);
  ctx2.save();
  ctx2.setLineDash([5,7]); ctx2.strokeStyle='rgba(240,239,234,.3)'; ctx2.lineWidth=1;
  ctx2.beginPath(); ctx2.moveTo(sp.x,sp.y); ctx2.lineTo(sp.x+dx*1.4,sp.y+dy*1.4); ctx2.stroke();
  ctx2.setLineDash([]); ctx2.strokeStyle='rgba(240,239,234,'+(0.15+power*0.5)+')'; ctx2.lineWidth=1;
  ctx2.beginPath(); ctx2.arc(sp.x,sp.y,dist*0.45,0,Math.PI*2); ctx2.stroke();
  ctx2.fillStyle='rgba(200,200,200,.7)'; ctx2.font='10px "Barlow Condensed",sans-serif'; ctx2.textAlign='left';
  ctx2.fillText('PUISSANCE '+Math.round(power*100)+'%', sp.x+14, sp.y-10);
  ctx2.restore();
}

function rTrail() {
  if (trail.length<2) return; ctx2.save();
  for (let i=1; i<trail.length; i++) {
    const a = (i/trail.length)*0.4;
    const p0 = w2s(trail[i-1].wx, trail[i-1].wy);
    const p1 = w2s(trail[i].wx,   trail[i].wy);
    ctx2.strokeStyle='rgba(240,239,234,'+a+')'; ctx2.lineWidth=1;
    ctx2.beginPath(); ctx2.moveTo(p0.x,p0.y); ctx2.lineTo(p1.x,p1.y); ctx2.stroke();
  }
  ctx2.fillStyle='rgba(240,239,234,.15)';
  for (let i=0; i<trail.length; i+=10) {
    const p = w2s(trail[i].wx, trail[i].wy);
    ctx2.beginPath(); ctx2.arc(p.x,p.y,1.5,0,Math.PI*2); ctx2.fill();
  }
  ctx2.restore();
}

function rMark() {
  const cp = w2s(pl.wx,0), gy = w2s(0,0).y;
  if (cp.x<-10||cp.x>cv2.width+10) return;
  ctx2.save();
  ctx2.strokeStyle='rgba(125,255,125,.4)'; ctx2.lineWidth=1; ctx2.setLineDash([3,5]);
  ctx2.beginPath(); ctx2.moveTo(cp.x,0); ctx2.lineTo(cp.x,gy); ctx2.stroke();
  ctx2.setLineDash([]); ctx2.fillStyle='#7dff7d';
  ctx2.font='bold 11px "Barlow Condensed",sans-serif'; ctx2.textAlign='center';
  ctx2.fillText('▼', cp.x, gy+22);
  ctx2.restore();
}

function rPlane() {
  let angle = 0;
  if (state==='flying')                      angle = Math.atan2(-pl.vy, pl.vx);
  else if (state==='idle'||state==='aiming') angle = -0.2;
  else                                       angle = 0.15;
  const cp = w2s(pl.wx, pl.wy);
  const s = cv2.width / 700;
  const isDelta = simAiles === 'delta';
  ctx2.save(); ctx2.translate(cp.x,cp.y); ctx2.rotate(angle); ctx2.scale(s,s);
  ctx2.fillStyle='#f0efea';
  if (isDelta) { ctx2.beginPath(); ctx2.moveTo(20,0); ctx2.lineTo(-24,-22); ctx2.lineTo(-8,0); ctx2.closePath(); ctx2.fill(); }
  else         { ctx2.beginPath(); ctx2.moveTo(20,0); ctx2.lineTo(-20,-8);  ctx2.lineTo(-8,-3); ctx2.closePath(); ctx2.fill(); }
  ctx2.fillStyle='#777';
  if (isDelta) { ctx2.beginPath(); ctx2.moveTo(20,0); ctx2.lineTo(-24,22);  ctx2.lineTo(-8,0); ctx2.closePath(); ctx2.fill(); }
  else         { ctx2.beginPath(); ctx2.moveTo(20,0); ctx2.lineTo(-20,-8);  ctx2.lineTo(-8,5); ctx2.closePath(); ctx2.fill(); }
  ctx2.fillStyle='#bbb'; ctx2.beginPath(); ctx2.moveTo(20,0); ctx2.lineTo(-8,-3); ctx2.lineTo(-8,3); ctx2.closePath(); ctx2.fill();
  ctx2.restore();
}
